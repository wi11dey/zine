{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "zine",
  "word": "identifier",
  "rules": {
    "text": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "token"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "STRING",
                "value": " "
              },
              {
                "type": "SYMBOL",
                "name": "token"
              }
            ]
          }
        }
      ]
    },
    "punctuation": {
      "type": "PATTERN",
      "value": "[.!?:;,]"
    },
    "span": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "keyword",
          "content": {
            "type": "PATTERN",
            "value": "[a-z]+\\{"
          }
        },
        {
          "type": "SYMBOL",
          "name": "text"
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "word": {
      "type": "PATTERN",
      "value": "[^ \\r\\n{}]+"
    },
    "display": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{{"
        },
        {
          "type": "SYMBOL",
          "name": "expression"
        },
        {
          "type": "STRING",
          "value": "}}"
        }
      ]
    },
    "inline": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "SYMBOL",
          "name": "expression"
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "_expression": {
      "type": "CHOICE",
      "members": [
        {
          "type": "PREC_LEFT",
          "value": 1,
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "STRING",
                "value": " "
              },
              {
                "type": "SYMBOL",
                "name": "_expression"
              }
            ]
          }
        },
        {
          "type": "SYMBOL",
          "name": "expression"
        }
      ]
    },
    "identifier": {
      "type": "PATTERN",
      "value": "[a-zA-Z]+"
    },
    "integer": {
      "type": "PATTERN",
      "value": "[0-9]+"
    },
    "superscript": {
      "type": "PREC_RIGHT",
      "value": 0,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "atom"
              },
              {
                "type": "SYMBOL",
                "name": "parens"
              }
            ]
          },
          {
            "type": "STRING",
            "value": "^"
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "atom"
              },
              {
                "type": "SYMBOL",
                "name": "parens"
              }
            ]
          }
        ]
      }
    },
    "subscript": {
      "type": "PREC_RIGHT",
      "value": 0,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "SYMBOL",
            "name": "atom"
          },
          {
            "type": "STRING",
            "value": "_"
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "atom"
              },
              {
                "type": "SYMBOL",
                "name": "parens"
              }
            ]
          }
        ]
      }
    },
    "postfix": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "atom"
        },
        {
          "type": "FIELD",
          "name": "operator",
          "content": {
            "type": "PATTERN",
            "value": "[!#']"
          }
        }
      ]
    },
    "noncommutative": {
      "type": "CHOICE",
      "members": [
        {
          "type": "PREC_LEFT",
          "value": 2,
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "SYMBOL",
                "name": "_expression"
              },
              {
                "type": "STRING",
                "value": " "
              },
              {
                "type": "SYMBOL",
                "name": "_expression"
              }
            ]
          }
        },
        {
          "type": "PREC_LEFT",
          "value": 0,
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "SYMBOL",
                "name": "parens"
              },
              {
                "type": "SYMBOL",
                "name": "parens"
              }
            ]
          }
        }
      ]
    },
    "commutative": {
      "type": "PREC_LEFT",
      "value": 3,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "SYMBOL",
            "name": "expression"
          },
          {
            "type": "FIELD",
            "name": "operator",
            "content": {
              "type": "CHOICE",
              "members": [
                {
                  "type": "STRING",
                  "value": " + "
                },
                {
                  "type": "STRING",
                  "value": " - "
                }
              ]
            }
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "expression"
              },
              {
                "type": "SYMBOL",
                "name": "ellipsis"
              }
            ]
          }
        ]
      }
    },
    "set": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "["
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "elements"
            },
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "expression"
                },
                {
                  "type": "STRING",
                  "value": "|"
                },
                {
                  "type": "SYMBOL",
                  "name": "expression"
                }
              ]
            }
          ]
        },
        {
          "type": "STRING",
          "value": "]"
        }
      ]
    },
    "bra": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "<"
        },
        {
          "type": "SYMBOL",
          "name": "expression"
        },
        {
          "type": "STRING",
          "value": "|"
        }
      ]
    },
    "ket": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "|"
        },
        {
          "type": "SYMBOL",
          "name": "expression"
        },
        {
          "type": "STRING",
          "value": ">"
        }
      ]
    },
    "projection": {
      "type": "PREC",
      "value": 1,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "<"
          },
          {
            "type": "SYMBOL",
            "name": "expression"
          },
          {
            "type": "STRING",
            "value": "|"
          },
          {
            "type": "SYMBOL",
            "name": "expression"
          },
          {
            "type": "STRING",
            "value": ">"
          }
        ]
      }
    },
    "interval": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "start",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "STRING",
                "value": "("
              },
              {
                "type": "STRING",
                "value": "["
              }
            ]
          }
        },
        {
          "type": "SYMBOL",
          "name": "expression"
        },
        {
          "type": "STRING",
          "value": ","
        },
        {
          "type": "SYMBOL",
          "name": "expression"
        },
        {
          "type": "FIELD",
          "name": "end",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "STRING",
                "value": ")"
              },
              {
                "type": "STRING",
                "value": "]"
              }
            ]
          }
        }
      ]
    },
    "parens": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "SYMBOL",
          "name": "expression"
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "elements": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "expression"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "STRING",
                "value": ","
              },
              {
                "type": "SYMBOL",
                "name": "expression"
              }
            ]
          }
        }
      ]
    },
    "ellipsis": {
      "type": "STRING",
      "value": "..."
    },
    "math": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "display"
        },
        {
          "type": "SYMBOL",
          "name": "inline"
        }
      ]
    },
    "token": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "span"
        },
        {
          "type": "SYMBOL",
          "name": "word"
        },
        {
          "type": "SYMBOL",
          "name": "math"
        }
      ]
    },
    "script": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "superscript"
        },
        {
          "type": "SYMBOL",
          "name": "subscript"
        }
      ]
    },
    "atom": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "identifier"
        },
        {
          "type": "SYMBOL",
          "name": "integer"
        },
        {
          "type": "SYMBOL",
          "name": "script"
        },
        {
          "type": "SYMBOL",
          "name": "postfix"
        }
      ]
    },
    "expression": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "atom"
        },
        {
          "type": "SYMBOL",
          "name": "noncommutative"
        },
        {
          "type": "SYMBOL",
          "name": "commutative"
        },
        {
          "type": "SYMBOL",
          "name": "set"
        },
        {
          "type": "SYMBOL",
          "name": "bra"
        },
        {
          "type": "SYMBOL",
          "name": "ket"
        },
        {
          "type": "SYMBOL",
          "name": "projection"
        },
        {
          "type": "SYMBOL",
          "name": "interval"
        },
        {
          "type": "SYMBOL",
          "name": "parens"
        }
      ]
    }
  },
  "extras": [],
  "conflicts": [
    [
      "interval",
      "elements"
    ]
  ],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [
    "math",
    "token",
    "script",
    "atom",
    "expression"
  ],
  "reserved": {}
}