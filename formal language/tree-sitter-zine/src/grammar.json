{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "zine",
  "word": "identifier",
  "rules": {
    "source": {
      "type": "SYMBOL",
      "name": "_expression"
    },
    "_expression": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_spacer"
        },
        {
          "type": "SYMBOL",
          "name": "_unspaced"
        }
      ]
    },
    "_unspaced": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "identifier"
        },
        {
          "type": "SYMBOL",
          "name": "integer"
        },
        {
          "type": "SYMBOL",
          "name": "multiplication"
        },
        {
          "type": "SYMBOL",
          "name": "commutative"
        },
        {
          "type": "SYMBOL",
          "name": "set"
        },
        {
          "type": "SYMBOL",
          "name": "bra"
        },
        {
          "type": "SYMBOL",
          "name": "ket"
        },
        {
          "type": "SYMBOL",
          "name": "projection"
        },
        {
          "type": "SYMBOL",
          "name": "interval"
        },
        {
          "type": "SYMBOL",
          "name": "parens"
        }
      ]
    },
    "ellipsis": {
      "type": "STRING",
      "value": "..."
    },
    "identifier": {
      "type": "PATTERN",
      "value": "[a-zA-Z]+"
    },
    "integer": {
      "type": "PATTERN",
      "value": "[0-9]+"
    },
    "_spacer": {
      "type": "PREC_LEFT",
      "value": 1,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": " "
          },
          {
            "type": "SYMBOL",
            "name": "_expression"
          }
        ]
      }
    },
    "multiplication": {
      "type": "CHOICE",
      "members": [
        {
          "type": "PREC_LEFT",
          "value": 2,
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "SYMBOL",
                "name": "_expression"
              },
              {
                "type": "STRING",
                "value": " "
              },
              {
                "type": "SYMBOL",
                "name": "_expression"
              }
            ]
          }
        },
        {
          "type": "PREC_LEFT",
          "value": 0,
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "SYMBOL",
                "name": "parens"
              },
              {
                "type": "SYMBOL",
                "name": "parens"
              }
            ]
          }
        }
      ]
    },
    "commutative": {
      "type": "PREC_LEFT",
      "value": 3,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "SYMBOL",
            "name": "_unspaced"
          },
          {
            "type": "FIELD",
            "name": "operator",
            "content": {
              "type": "CHOICE",
              "members": [
                {
                  "type": "STRING",
                  "value": " + "
                },
                {
                  "type": "STRING",
                  "value": " - "
                }
              ]
            }
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "_unspaced"
              },
              {
                "type": "SYMBOL",
                "name": "ellipsis"
              }
            ]
          }
        ]
      }
    },
    "set": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "SYMBOL",
          "name": "_unspaced"
        },
        {
          "type": "STRING",
          "value": "|"
        },
        {
          "type": "SYMBOL",
          "name": "_unspaced"
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "bra": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "<"
        },
        {
          "type": "SYMBOL",
          "name": "_unspaced"
        },
        {
          "type": "STRING",
          "value": "|"
        }
      ]
    },
    "ket": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "|"
        },
        {
          "type": "SYMBOL",
          "name": "_unspaced"
        },
        {
          "type": "STRING",
          "value": ">"
        }
      ]
    },
    "projection": {
      "type": "PREC",
      "value": 1,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "<"
          },
          {
            "type": "SYMBOL",
            "name": "_unspaced"
          },
          {
            "type": "STRING",
            "value": "|"
          },
          {
            "type": "SYMBOL",
            "name": "_unspaced"
          },
          {
            "type": "STRING",
            "value": ">"
          }
        ]
      }
    },
    "interval": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "start",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "STRING",
                "value": "("
              },
              {
                "type": "STRING",
                "value": "["
              }
            ]
          }
        },
        {
          "type": "SYMBOL",
          "name": "_unspaced"
        },
        {
          "type": "STRING",
          "value": ","
        },
        {
          "type": "SYMBOL",
          "name": "_unspaced"
        },
        {
          "type": "FIELD",
          "name": "end",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "STRING",
                "value": ")"
              },
              {
                "type": "STRING",
                "value": "]"
              }
            ]
          }
        }
      ]
    },
    "parens": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "SYMBOL",
          "name": "_unspaced"
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    }
  },
  "extras": [],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}